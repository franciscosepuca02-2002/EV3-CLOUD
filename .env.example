# ============================================
# EV3 Cloud - Variables de Entorno
# Copiar como .env y llenar los valores
# ============================================

# --- Base de datos (RDS) ---
DATABASE_URL=postgresql://postgres:TU_PASSWORD@TU_ENDPOINT_RDS:5432/ev3clouddb

# --- JWT ---
SECRET_KEY=cambiar-por-una-clave-segura-aleatoria

# --- Mercado Pago ---
MP_ACCESS_TOKEN=APP_USR-xxxxx
MP_PUBLIC_KEY=APP_USR-xxxxx

# URLs de retorno de Mercado Pago (reemplazar IP con tu Elastic IP)
MP_SUCCESS_URL=http://TU_ELASTIC_IP/payment/success
MP_FAILURE_URL=http://TU_ELASTIC_IP/payment/failure
MP_PENDING_URL=http://TU_ELASTIC_IP/payment/pending
MP_WEBHOOK_URL=http://TU_ELASTIC_IP:8000/api/payments/webhook

# --- AWS ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-2
S3_BUCKET_NAME=ev3-cloud-storage-tu-nombre

# --- Amazon SES ---
# NOTA: SES puede no estar disponible en us-east-2.
# Si usas otra región para SES, ponla aquí:
AWS_SES_REGION=us-east-1
SES_SENDER_EMAIL=tu-email-verificado@gmail.com

# --- Twilio ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# --- URLs de microservicios (Docker Compose network) ---
PAYMENT_SERVICE_URL=http://app-pagos:8002
NOTIFICATION_SERVICE_URL=http://app-notificaciones:8001

# --- URL pública del frontend ---
FRONTEND_URL=http://TU_ELASTIC_IP
